class Solution {
    public int largestAltitude(int[] gain) {
        int[] arr = new int[gain.length+1];
        int j = 1;
        for(int i = 0; i < gain.length; i++){
            arr[j] = arr[j-1] + gain[i];
            j++;
        }
        int max = Integer.MIN_VALUE;
        for(int i = 0; i < arr.length; i++){
            if(max<arr[i]){
                max = arr[i];
            }
        }
        return max;
    }
}
